{
  "name": "agentsync",
  "version": "0.1.0",
  "description": "Manage your AI coding agent configs in one place. One MCP config for every tool. Sync between devices with git.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "agentsync": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup && cp -r agents dist/agents",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agents",
    "mcp",
    "config",
    "sync",
    "claude",
    "codex"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "simple-git": "^3.33.0",
    "smol-toml": "^1.6.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
